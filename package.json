{
  "name": "hotel-price-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hotel-price-ihg-mcp": "dist/mcp/ihgMcpServer.js"
  },
  "scripts": {
    "dev": "npm run build && node dist/app.js",
    "dev:tsx": "tsx src/app.ts",
    "dev:watch": "tsx watch src/app.ts",
    "debug:provider": "npm run build && node dist/debug/runProvider.js",
    "debug:provider:tsx": "tsx src/debug/runProvider.ts",
    "mcp:ihg": "npm run build && node dist/mcp/ihgMcpServer.js",
    "start": "node dist/app.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cloakbrowser": "latest",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mmdb-lib": "^3.0.2",
    "pino": "^9.6.0",
    "playwright-core": "^1.49.1",
    "proxy-chain": "^3.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
